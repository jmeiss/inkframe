{
  "name": "inkframe",
  "version": "1.0.0",
  "description": "Google Photos E-Paper Display Server for Seeed Studio reTerminal E1002",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "node --watch src/index.js",
    "client:dev": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "NODE_ENV=production node src/index.js",
    "install:all": "npm install && npm --prefix client install",
    "clean": "rm -rf node_modules client/node_modules client/dist",
    "deploy:prod": "bash deploy.sh",
    "logs:prod": "ssh docker 'docker logs --tail 50 -f inkframe'",
    "test": "node --test test/*.test.js",
    "test:all": "npm test",
    "service:start": "launchctl start com.inkframe.server",
    "service:stop": "launchctl stop com.inkframe.server",
    "service:restart": "launchctl stop com.inkframe.server && sleep 1 && launchctl start com.inkframe.server",
    "service:status": "launchctl list | grep inkframe || echo 'Service not running'"
  },
  "keywords": [
    "e-paper",
    "google-photos",
    "acep",
    "dithering",
    "image-processing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
